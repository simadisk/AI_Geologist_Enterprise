# 1. Παίρνουμε μια καθαρή, ελαφριά έκδοση της Python
FROM python:3.10-slim

# 2. Ρύθμιση για να βλέπουμε ΟΛΑ τα logs (print) αμέσως στο τερματικό!
ENV PYTHONUNBUFFERED=1

# 3. Φτιάχνουμε έναν φάκελο /app μέσα στον εικονικό server
WORKDIR /app

# 4. Αντιγράφουμε τη λίστα με τις βιβλιοθήκες και τις κάνουμε install
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 5. Αντιγράφουμε ΟΛΑ τα αρχεία του φακέλου (κώδικα ΚΑΙ μοντέλα)
COPY . .

# 6. Ανοίγουμε την πόρτα 8000
EXPOSE 8000

# 7. Η εντολή που θα τρέχει το API (Αφαιρέσαμε τον περιορισμό του χρήστη για να έχουμε πλήρη δικαιώματα)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]